---
import { languages } from '../data/content.js';

const { page, lang } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const withBase = (path = '') => `${baseUrl}${path.replace(/^\/+/, '')}`;
const otherLanguages = Object.values(languages);
const isExternal = (href = '') => href.startsWith('http') || href.startsWith('mailto:');
const linkTarget = (href = '') => (isExternal(href) && !href.startsWith('mailto:') ? '_blank' : undefined);
const linkRel = (href = '') => (isExternal(href) && !href.startsWith('mailto:') ? 'noreferrer' : undefined);
const brandInitial = page.profile.name.trim().charAt(0) || 'N';
const heroImageSrc = page.hero.image.src.startsWith('http') ? page.hero.image.src : withBase(page.hero.image.src);
const ui =
  lang === 'es'
    ? {
        skip: 'Saltar al contenido',
        primaryActions: 'Acciones principales',
        technicalFocus: 'Foco técnico',
        technologies: 'Tecnologías',
        project: 'proyecto',
        open: 'Abrir',
      }
    : {
        skip: 'Skip to content',
        primaryActions: 'Primary actions',
        technicalFocus: 'Technical focus',
        technologies: 'Technologies',
        project: 'project',
        open: 'Open',
      };
---

<span class="top-anchor" id="top" aria-hidden="true"></span>
<a class="skip-link" href="#main">{ui.skip}</a>

<header class="site-header">
  <nav class="nav-shell" aria-label={page.navigation.ariaLabel}>
    <a class="brand" href={withBase(languages[lang].path)} aria-label={page.profile.name}>
      <span class="brand-mark" aria-hidden="true">{brandInitial}</span>
      <span class="brand-text">{page.profile.name}</span>
    </a>

    <div class="nav-links">
      {page.navigation.links.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>

    <div class="language-switcher" aria-label={page.navigation.languageLabel}>
      {
        otherLanguages.map((language) => (
          <a
            class:list={['language-link', { active: language.code === lang }]}
            href={withBase(language.path)}
            hreflang={language.code}
            aria-current={language.code === lang ? 'page' : undefined}
          >
            {language.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<main id="main">
  <section class="hero" aria-labelledby="hero-title">
    <img class="hero-image" src={heroImageSrc} alt={page.hero.image.alt} loading="eager" decoding="async" />
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="eyebrow">{page.hero.eyebrow}</p>
      <h1 id="hero-title">{page.hero.title}</h1>
      <p class="hero-value">{page.hero.value}</p>

      <div class="hero-actions" aria-label={ui.primaryActions}>
        <a class="button button-primary" href={page.hero.primaryCta.href}>{page.hero.primaryCta.label}</a>
        <a class="button button-secondary" href={page.hero.secondaryCta.href}>{page.hero.secondaryCta.label}</a>
      </div>
    </div>
    {
      page.hero.image.credit && page.hero.image.creditUrl && (
        <a class="image-credit" href={page.hero.image.creditUrl} target="_blank" rel="noreferrer">
          {page.hero.image.credit}
        </a>
      )
    }
  </section>

  <section class="section section-about" id={page.about.id} aria-labelledby={`${page.about.id}-title`}>
    <div class="container two-column">
      <div class="section-heading">
        <p class="eyebrow">{page.about.eyebrow}</p>
        <h2 id={`${page.about.id}-title`}>{page.about.title}</h2>
      </div>

      <div class="about-content">
        {page.about.body.map((paragraph) => <p>{paragraph}</p>)}
        <div class="principles">
          {
            page.about.principles.map((principle) => (
              <article class="principle">
                <h3>{principle.label}</h3>
                <p>{principle.text}</p>
              </article>
            ))
          }
        </div>
      </div>

      <aside class="strengths-panel" aria-labelledby="strengths-title">
        <h3 id="strengths-title">{page.about.strengthsTitle}</h3>
        <ul class="check-list">
          {page.about.strengths.map((strength) => <li>{strength}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section" id={page.experience.id} aria-labelledby={`${page.experience.id}-title`}>
    <div class="container">
      <div class="section-heading wide">
        <p class="eyebrow">{page.experience.eyebrow}</p>
        <h2 id={`${page.experience.id}-title`}>{page.experience.title}</h2>
        <p>{page.experience.intro}</p>
      </div>

      <div class="timeline">
        {
          page.experience.items.map((item) => (
            <article class="timeline-item">
              <div class="timeline-meta">
                <span>{item.period}</span>
              </div>
              <div class="timeline-body">
                <h3>{item.role}</h3>
                <p class="muted">{item.company}</p>
                <p>{item.context}</p>
                <ul>
                  {item.highlights.map((highlight) => <li>{highlight}</li>)}
                </ul>
                <div class="tag-list" aria-label={ui.technologies}>
                  {item.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-projects" id={page.projects.id} aria-labelledby={`${page.projects.id}-title`}>
    <div class="container">
      <div class="section-heading wide">
        <p class="eyebrow">{page.projects.eyebrow}</p>
        <h2 id={`${page.projects.id}-title`}>{page.projects.title}</h2>
        <p>{page.projects.intro}</p>
      </div>

      <div class="project-grid">
        {
          page.projects.items.map((project) => (
            <article class="project-card">
              <div class="project-card-top">
                <span class="project-kicker">{project.kicker ?? ui.project}</span>
                {project.link && project.link !== '#' && (
                  <a href={project.link} target={linkTarget(project.link)} rel={linkRel(project.link)}>
                    {ui.open}
                  </a>
                )}
              </div>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <p class="impact">{project.impact}</p>
              <div class="tag-list" aria-label={ui.technologies}>
                {project.technologies.map((technology) => <span>{technology}</span>)}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id={page.skills.id} aria-labelledby={`${page.skills.id}-title`}>
    <div class="container">
      <div class="section-heading wide">
        <p class="eyebrow">{page.skills.eyebrow}</p>
        <h2 id={`${page.skills.id}-title`}>{page.skills.title}</h2>
        <p>{page.skills.intro}</p>
      </div>

      <div class="skill-grid">
        {
          page.skills.categories.map((category) => (
            <article class="skill-card">
              <h3>{category.name}</h3>
              <ul>
                {category.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-education" id={page.education.id} aria-labelledby={`${page.education.id}-title`}>
    <div class="container">
      <div class="section-heading wide">
        <p class="eyebrow">{page.education.eyebrow}</p>
        <h2 id={`${page.education.id}-title`}>{page.education.title}</h2>
      </div>

      <div class="credential-list">
        {
          page.education.items.map((item) => (
            <article class="credential-item">
              <div>
                <h3>{item.title}</h3>
                <p class="muted">{item.institution}</p>
                <p>{item.description}</p>
              </div>
              <time>{item.period}</time>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section contact-section" id={page.contact.id} aria-labelledby={`${page.contact.id}-title`}>
    <div class="container contact-shell">
      <div class="section-heading">
        <p class="eyebrow">{page.contact.eyebrow}</p>
        <h2 id={`${page.contact.id}-title`}>{page.contact.title}</h2>
        {page.contact.text && <p>{page.contact.text}</p>}
      </div>

      <address class="contact-card">
        {
          page.profile.email && page.contact.emailLabel && (
            <>
              <p class="contact-label">{page.contact.emailLabel}</p>
              <a class="contact-email" href={`mailto:${page.profile.email}`}>{page.profile.email}</a>
            </>
          )
        }
        <p class="contact-label">{page.contact.socialLabel}</p>
        <div class="contact-links">
          {
            page.contact.links.map((link) => (
              <a href={link.href} target={linkTarget(link.href)} rel={linkRel(link.href)}>
                {link.label}
              </a>
            ))
          }
        </div>
      </address>
    </div>
  </section>
</main>

<footer class="site-footer">
  <div class="container footer-inner">
    <p>{page.footer.text}</p>
    <a class="back-to-top" href="#top">{page.footer.backToTop}</a>
  </div>
</footer>

<script is:inline>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reducedMotion) {
    document.documentElement.classList.add('reveal-ready');

    const revealSelectors = [
      '.section-heading',
      '.about-content > p',
      '.principle',
      '.strengths-panel',
      '.timeline-item',
      '.project-card',
      '.skill-card',
      '.credential-item',
      '.contact-card',
    ];

    const revealItems = document.querySelectorAll(revealSelectors.join(','));

    revealItems.forEach((item, index) => {
      item.classList.add('reveal');
      item.style.setProperty('--reveal-delay', `${Math.min(index % 4, 3) * 70}ms`);
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        rootMargin: '0px 0px -12% 0px',
        threshold: 0.16,
      },
    );

    revealItems.forEach((item) => observer.observe(item));
  }

  document.querySelectorAll('.back-to-top').forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      window.scrollTo({
        top: 0,
        behavior: reducedMotion ? 'auto' : 'smooth',
      });
      history.replaceState(null, '', window.location.pathname + window.location.search);
    });
  });
</script>
